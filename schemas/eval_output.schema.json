{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinalQaEvalOutput",
  "type": "object",
  "required": [
    "run_id",
    "case_id",
    "config_id",
    "provider",
    "model",
    "qa_category",
    "question_type",
    "qa_topic",
    "instruction",
    "output",
    "model_answer",
    "acc",
    "com",
    "utl",
    "nac",
    "hal",
    "overall_score",
    "latency_ms",
    "status",
    "error",
    "raw_response"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "case_id": {"type": "string"},
    "config_id": {"type": "string"},
    "provider": {"type": "string"},
    "model": {"type": "string"},
    "qa_category": {"enum": ["BC FAQ", "금융정보", "카드상품"]},
    "question_type": {"enum": ["단일추론(사실추출)", "비교대조", "복합추론", "수치추론/계산", "민감"]},
    "qa_topic": {"enum": ["카드/결제", "대출/여신", "예적금", "투자/펀드", "일반 금융"]},
    "instruction": {"type": "string"},
    "output": {"type": "string"},
    "model_answer": {"type": "string"},
    "acc": {"type": "number", "minimum": 0, "maximum": 20},
    "com": {"type": "number", "minimum": 0, "maximum": 20},
    "utl": {"type": "number", "minimum": 0, "maximum": 20},
    "nac": {"type": "number", "minimum": 0, "maximum": 20},
    "hal": {"type": "number", "minimum": 0, "maximum": 20},
    "overall_score": {"type": "number", "minimum": 0, "maximum": 100},
    "latency_ms": {"type": "number"},
    "status": {"type": "string"},
    "error": {"type": ["string", "null"]},
    "raw_response": {"type": "object"}
  }
}
