{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CanonicalDocument",
  "type": "object",
  "required": [
    "document_id",
    "source_id",
    "source_group",
    "source_type",
    "authority_level",
    "title",
    "source_url_or_path",
    "source_hash",
    "content_format",
    "pii_level",
    "license_scope",
    "metadata"
  ],
  "properties": {
    "document_id": {"type": "string"},
    "source_id": {"type": "string"},
    "source_group": {"type": "string"},
    "source_type": {"type": "string"},
    "authority_level": {"type": "string"},
    "title": {"type": "string"},
    "version": {"type": ["string", "null"]},
    "effective_date": {"type": ["string", "null"]},
    "collected_at": {"type": "string"},
    "source_url_or_path": {"type": "string"},
    "source_hash": {"type": "string"},
    "content_format": {"type": "string"},
    "pii_level": {"type": "string"},
    "license_scope": {"type": "string"},
    "metadata": {"type": "object"}
  }
}
