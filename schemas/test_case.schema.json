{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RegressionTestCase",
  "type": "object",
  "required": [
    "case_id",
    "status",
    "suite",
    "priority",
    "severity",
    "intent",
    "task_type",
    "expected_behavior",
    "qa_category",
    "question_type",
    "qa_topic",
    "instruction",
    "output",
    "question",
    "gold_answer",
    "gold_evidence",
    "required_conditions",
    "forbidden_claims",
    "expected_tool_path",
    "scoring_rubric",
    "metadata"
  ],
  "properties": {
    "case_id": {"type": "string"},
    "status": {"enum": ["candidate", "shadow", "active", "deprecated"]},
    "suite": {"type": "string"},
    "priority": {"type": "string"},
    "severity": {"type": "string"},
    "intent": {"type": "string"},
    "task_type": {"type": "string"},
    "qa_category": {"enum": ["BC FAQ", "금융정보", "카드상품"]},
    "question_type": {"enum": ["단일추론(사실추출)", "비교대조", "복합추론", "수치추론/계산", "민감"]},
    "qa_topic": {"enum": ["카드/결제", "대출/여신", "예적금", "투자/펀드", "일반 금융"]},
    "expected_behavior": {
      "type": "string",
      "enum": [
        "answer_from_source",
        "answer_from_source_with_json_format",
        "answer_from_sample_evidence",
        "answer_from_sample_evidence_without_pii",
        "answer_not_supported_or_refuse",
        "abstain_when_unsupported",
        "refuse_unsafe_request",
        "ask_clarifying_question",
        "tool_call_then_grounded_answer",
        "tool_call_then_answer",
        "tool_result_synthesis",
        "tool_creation_and_use",
        "structured_output_required"
      ]
    },
    "source_mode": {"type": "string"},
    "instruction": {"type": "string"},
    "output": {"type": "string"},
    "question": {"type": "string"},
    "conversation_turns": {"type": "array"},
    "gold_answer": {"type": ["string", "null"]},
    "gold_evidence": {"type": "array"},
    "required_conditions": {"type": "array", "items": {"type": "string"}},
    "forbidden_claims": {"type": "array", "items": {"type": "string"}},
    "expected_tool_path": {"type": "array", "items": {"type": "string"}},
    "expected_tool_calls": {"type": "array"},
    "expected_final_answer": {"type": "object"},
    "format_requirements": {"type": "object"},
    "scoring_rubric": {"type": "object"},
    "metadata": {"type": "object"}
  }
}
