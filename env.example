FINAL_UI_AUTH_USERS=admin:change-me:admin,user:change-me:user
# Resolve the real browser/client IP when Final UI is behind Cloudflare or a reverse proxy.
# cloudflare = trust Cloudflare ranges plus local/private reverse proxies.
# Use strict_cloudflare to trust only Cloudflare ranges, all to trust every peer, or none to disable.
FINAL_UI_TRUST_PROXY_HEADERS=cloudflare
# Add explicit proxy CIDRs/IPs when your gateway is not covered by the default local/private ranges.
# FINAL_UI_TRUSTED_PROXIES=192.168.0.254,127.0.0.1
OLLAMA_BASE_URL=http://afsd.iptime.org:11434
# Commercial Judge/API presets:
# You can set keys here, or paste them while registering a Judge model in the admin UI.
# Admin UI saved keys are stored locally in final_UI/data/server_api_secrets.json (ignored by git).
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_API_URL=https://generativelanguage.googleapis.com
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# CLOVA_STUDIO_API_KEY=your-clova-studio-api-key
